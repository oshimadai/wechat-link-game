/* 1V1 连线桌游 - 微信小程序样式 */
/* 版本：v3.22 - 正确布局版 */

/* 全局样式 */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
  max-width: 1200rpx;
  margin: 0 auto;
}

/* 游戏标题 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 3rpx solid #667eea;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

/* 玩家信息栏 */
.game-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.player-info {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 20rpx 30rpx;
  border-radius: 15rpx;
  min-width: 200rpx;
  text-align: center;
  flex: 1;
}

.player-info.active {
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.8);
  border: 3rpx solid gold;
}

.player-name {
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.player-score {
  font-size: 40rpx;
  font-weight: bold;
}

.player-penalty {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.9;
}

.token-display {
  display: flex;
  gap: 10rpx;
  justify-content: center;
  margin-top: 10rpx;
}

.token {
  font-size: 24rpx;
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
  color: white;
}

.token.fire {
  background: #ff6b6b;
}

.token.water {
  background: #4facfe;
}

.token.wood {
  background: #43e97b;
}

/* 回合信息 */
.turn-info {
  text-align: center;
  padding: 20rpx;
  flex: 1;
}

.turn-indicator {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
}

.round-display {
  font-size: 28rpx;
  margin-top: 10rpx;
  color: #666;
}

.action-prompt {
  font-size: 24rpx;
  margin-top: 5rpx;
  color: #999;
}

.cancel-btn {
  margin-top: 10rpx;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background: #dc3545;
  color: white;
  border-radius: 8rpx;
}

/* 游戏桌面 */
.game-board {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

/* 玩家区域 */
.player-area {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 20rpx;
  border: 3rpx solid #dee2e6;
  position: relative;
}

.player-area.active {
  border-color: #667eea;
  box-shadow: 0 0 20rpx rgba(102, 126, 234, 0.5);
}

.area-title {
  color: #667eea;
  font-size: 28rpx;
  margin-bottom: 15rpx;
  font-weight: bold;
}

/* 卡牌行 */
.card-row {
  display: flex;
  gap: 10rpx;
  justify-content: center;
  flex-wrap: nowrap;
  min-height: 280rpx;
  align-items: center;
}

/* 卡牌样式 */
.card {
  width: 140rpx;
  height: 200rpx;
  border-radius: 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 15rpx;
  position: relative;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.card:hover {
  transform: translateY(-10rpx);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
}

/* 属性颜色 */
.card.fire {
  background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
  color: white;
}

.card.water {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
  color: white;
}

.card.wood {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
  color: white;
}

.card.wild {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: white;
  border: 3rpx solid gold;
}

.card.triggered {
  opacity: 0.5;
}

.card-empty {
  width: 140rpx;
  height: 200rpx;
  border-radius: 15rpx;
  background: #e9ecef;
  border: 2rpx dashed #adb5bd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-slot {
  width: 100rpx;
  height: 160rpx;
  border-radius: 10rpx;
}

/* 选中效果 */
.card.selected {
  border-color: gold;
  box-shadow: 0 0 20rpx gold;
}

.card.selectable {
  border-color: #00ff00 !important;
  box-shadow: 0 0 20rpx #00ff00 !important;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 卡牌内容 */
.card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 100%;
}

.card-attr {
  font-size: 48rpx;
}

.card-arrow {
  font-size: 56rpx;
  font-weight: bold;
}

/* 血量格子 */
.card-hp-container {
  display: flex;
  gap: 4rpx;
  margin-top: 10rpx;
}

.card-hp-slot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.card-hp-slot.filled {
  /* 默认白色，属性会覆盖 */
}

.card.fire .card-hp-slot.filled {
  background: #ff6b6b;
  box-shadow: 0 0 5rpx #ff6b6b;
}

.card.water .card-hp-slot.filled {
  background: #4facfe;
  box-shadow: 0 0 5rpx #4facfe;
}

.card.wood .card-hp-slot.filled {
  background: #43e97b;
  box-shadow: 0 0 5rpx #43e97b;
}

.card.wild .card-hp-slot.filled {
  background: #f093fb;
  box-shadow: 0 0 5rpx #f093fb;
}

.card-hp-slot.empty {
  background: transparent;
}

.card-hp-slot.skull {
  background: #ff0000;
  animation: skullPulse 1s infinite;
}

@keyframes skullPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.card-score {
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.3);
  padding: 5rpx 15rpx;
  border-radius: 10rpx;
}

.card-ability {
  font-size: 32rpx;
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 玩家 2 区域：旋转 180° */
.player2-area {
  transform: rotate(180deg);
}

.player2-area .card {
  transform: rotate(180deg);
}

.player2-area .card:hover {
  transform: rotate(180deg) translateY(-10rpx);
}

.player2-area .card.selected {
  transform: rotate(180deg);
}

.player2-area .card.selectable {
  transform: rotate(180deg) !important;
}

/* 中间区域 */
.center-area {
  text-align: center;
  padding: 20rpx;
}

.token-bar {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.token-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 3rpx solid white;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.3);
}

.token-btn.fire {
  background: #ff6b6b;
}

.token-btn.water {
  background: #4facfe;
}

.token-btn.wood {
  background: #43e97b;
}

/* 已触发卡牌区域 */
.triggered-area {
  background: #e9ecef;
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  min-height: 150rpx;
}

.triggered-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.triggered-card {
  width: 80rpx;
  height: 110rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0.7;
}

.triggered-card.fire {
  background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
}

.triggered-card.water {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.triggered-card.wood {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
}

.triggered-card.wild {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.triggered-attr {
  font-size: 32rpx;
}

.triggered-score {
  font-size: 20rpx;
  color: white;
  margin-top: 5rpx;
}

/* 游戏日志 */
.game-log {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  max-height: 400rpx;
}

.log-title {
  color: #667eea;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.log-content {
  max-height: 300rpx;
}

.log-entry {
  padding: 8rpx 0;
  border-bottom: 1rpx solid #dee2e6;
  font-size: 24rpx;
  color: #333;
}

/* 控制按钮 */
.controls {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 30rpx;
}

.btn {
  padding: 20rpx 50rpx;
  font-size: 28rpx;
  border-radius: 15rpx;
  border: none;
  font-weight: bold;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}

.btn-secondary {
  background: #6c757d;
  color: white;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  padding: 50rpx;
  border-radius: 20rpx;
  text-align: center;
  max-width: 600rpx;
}

.winner-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 20rpx;
}

.final-score {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 30rpx;
}

/* 规则弹窗 */
.rules-content {
  text-align: left;
  max-width: 800rpx;
}

.rules-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  text-align: center;
  margin-bottom: 30rpx;
}

.rules-scroll {
  max-height: 800rpx;
  padding: 20rpx;
}

.rules-section {
  margin-bottom: 30rpx;
}

.rules-subtitle {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 15rpx;
}

.rules-text {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

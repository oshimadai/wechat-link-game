<!-- 1V1 连线桌游 - 微信小程序 -->
<!-- 版本：v3.22 - 正确布局版 -->

<view class="container">
  <!-- 游戏标题 -->
  <view class="header">
    <view class="title">🔗 1V1 连线桌游 v3.22</view>
    <view class="subtitle">血量格子版 | 面对面设计</view>
  </view>

  <!-- 玩家信息栏 -->
  <view class="game-info">
    <view class="player-info {{currentPlayer === 1 ? 'active' : ''}}">
      <view class="player-name">👤 玩家 1</view>
      <view class="player-score">{{score1}} 分</view>
      <view class="player-penalty">扣分：{{penalty1}}</view>
      <view class="token-display">
        <view class="token fire" wx:if="{{tokens.fire > 0}}">🔥×{{tokens.fire}}</view>
        <view class="token water" wx:if="{{tokens.water > 0}}">💧×{{tokens.water}}</view>
        <view class="token wood" wx:if="{{tokens.wood > 0}}">🌿×{{tokens.wood}}</view>
      </view>
    </view>

    <view class="turn-info">
      <view class="turn-indicator">{{currentPlayer === 1 ? '玩家 1' : '玩家 2'}}的回合</view>
      <view class="round-display">回合：{{round}}</view>
      <view class="action-prompt">{{actionPrompt}}</view>
      <button class="cancel-btn" wx:if="{{selectedCard}}" bindtap="cancelSelection">❌ 取消选择</button>
    </view>

    <view class="player-info {{currentPlayer === 2 ? 'active' : ''}}">
      <view class="player-name">👤 玩家 2</view>
      <view class="player-score">{{score2}} 分</view>
      <view class="player-penalty">扣分：{{penalty2}}</view>
      <view class="token-display">
        <view class="token fire" wx:if="{{tokens.fire > 0}}">🔥×{{tokens.fire}}</view>
        <view class="token water" wx:if="{{tokens.water > 0}}">💧×{{tokens.water}}</view>
        <view class="token wood" wx:if="{{tokens.wood > 0}}">🌿×{{tokens.wood}}</view>
      </view>
    </view>
  </view>

  <!-- 游戏桌面 -->
  <view class="game-board">
    <!-- 玩家 1 区域（上方） -->
    <view class="player-area {{currentPlayer === 1 ? 'active' : ''}}" id="player1-area">
      <view class="area-title">👤 玩家 1 区域</view>
      <view class="card-row">
        <view 
          class="card {{card.attr}} {{card.triggered ? 'triggered' : ''}} {{card.selected ? 'selected' : ''}} {{card.selectable ? 'selectable' : ''}}"
          wx:for="{{player1Cards}}" 
          wx:key="id"
          data-player="1"
          data-index="{{index}}"
          bindtap="handleCardTap"
        >
          <view class="card-content" wx:if="{{card}}">
            <view class="card-attr">{{card.attrEmoji}}</view>
            <view class="card-arrow">{{card.arrow}}</view>
            <view class="card-hp-container">
              <view 
                class="card-hp-slot {{hpSlot.filled ? 'filled' : 'empty'}} {{hpSlot.skull ? 'skull' : ''}}"
                wx:for="{{card.hpSlots}}" 
                wx:key="index"
                wx:for-item="hpSlot"
              ></view>
            </view>
            <view class="card-score">+{{card.score}}</view>
            <view class="card-ability" wx:if="{{card.ability}}" data-ability="{{card.ability.icon}}" bindtap="handleAbilityTap">
              {{card.ability.icon}}
            </view>
          </view>
          <view class="card-empty" wx:else>
            <view class="empty-slot"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 中间区域 -->
    <view class="center-area">
      <view class="token-bar">
        <view class="token-btn fire" bindtap="useToken" data-type="fire">🔥</view>
        <view class="token-btn water" bindtap="useToken" data-type="water">💧</view>
        <view class="token-btn wood" bindtap="useToken" data-type="wood">🌿</view>
      </view>
    </view>

    <!-- 玩家 2 区域（下方，旋转 180°） -->
    <view class="player-area player2-area {{currentPlayer === 2 ? 'active' : ''}}" id="player2-area">
      <view class="area-title">👤 玩家 2 区域</view>
      <view class="card-row">
        <view 
          class="card {{card.attr}} {{card.triggered ? 'triggered' : ''}} {{card.selected ? 'selected' : ''}} {{card.selectable ? 'selectable' : ''}}"
          wx:for="{{player2Cards}}" 
          wx:key="id"
          data-player="2"
          data-index="{{index}}"
          bindtap="handleCardTap"
        >
          <view class="card-content" wx:if="{{card}}">
            <view class="card-attr">{{card.attrEmoji}}</view>
            <view class="card-arrow">{{card.arrow}}</view>
            <view class="card-hp-container">
              <view 
                class="card-hp-slot {{hpSlot.filled ? 'filled' : 'empty'}} {{hpSlot.skull ? 'skull' : ''}}"
                wx:for="{{card.hpSlots}}" 
                wx:key="index"
                wx:for-item="hpSlot"
              ></view>
            </view>
            <view class="card-score">+{{card.score}}</view>
            <view class="card-ability" wx:if="{{card.ability}}" data-ability="{{card.ability.icon}}" bindtap="handleAbilityTap">
              {{card.ability.icon}}
            </view>
          </view>
          <view class="card-empty" wx:else>
            <view class="empty-slot"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 已触发卡牌区域 -->
  <view class="triggered-area">
    <view class="area-title">📊 已触发卡牌（计分区）</view>
    <view class="triggered-row">
      <view class="triggered-card {{card.attr}}" wx:for="{{triggeredCards}}" wx:key="id">
        <view class="triggered-attr">{{card.attrEmoji}}</view>
        <view class="triggered-score">+{{card.score}}</view>
      </view>
    </view>
  </view>

  <!-- 游戏日志 -->
  <view class="game-log">
    <view class="log-title">📜 游戏日志</view>
    <scroll-view class="log-content" scroll-y="true">
      <view class="log-entry" wx:for="{{gameLog}}" wx:key="index">
        {{entry}}
      </view>
    </scroll-view>
  </view>

  <!-- 控制按钮 -->
  <view class="controls">
    <button class="btn btn-primary" bindtap="startGame">🎮 开始新游戏</button>
    <button class="btn btn-secondary" bindtap="showRules">📖 游戏规则</button>
  </view>
</view>

<!-- 游戏结束弹窗 -->
<view class="modal" wx:if="{{gameOver}}">
  <view class="modal-content">
    <view class="winner-text">{{winnerText}}</view>
    <view class="final-score">{{finalScore}}</view>
    <button class="btn btn-primary" bindtap="startGame">再来一局</button>
  </view>
</view>

<!-- 规则弹窗 -->
<view class="modal" wx:if="{{showRulesModal}}">
  <view class="modal-content rules-content">
    <view class="rules-title">📖 游戏规则</view>
    <scroll-view class="rules-scroll" scroll-y="true">
      <view class="rules-section">
        <view class="rules-subtitle">🎯 游戏目标</view>
        <view class="rules-text">率先达到 20 分的玩家获胜（对方获得公平回合）。</view>
      </view>
      <view class="rules-section">
        <view class="rules-subtitle">🃏 卡牌属性</view>
        <view class="rules-text">🔥 火、💧 水、🌿 木：三种属性</view>
        <view class="rules-text">🌈 万能：可当作任意属性使用</view>
        <view class="rules-text">血量：3 血/2 血/1 血/0 血/∞血</view>
        <view class="rules-text">分数：3 血=1 分，2 血=2 分，1 血=3 分，0 血=0 分</view>
      </view>
      <view class="rules-section">
        <view class="rules-subtitle">🔗 连线规则</view>
        <view class="rules-text">只能连接相同属性的卡牌</view>
        <view class="rules-text">万能卡可以连接任意属性</view>
        <view class="rules-text">箭头方向决定连线路径（↑↓→←）</view>
        <view class="rules-text">连线长度≥3 张可获得 Token</view>
      </view>
      <view class="rules-section">
        <view class="rules-subtitle">⏳ 衰减规则</view>
        <view class="rules-text">每回合结束，未触发的卡牌 -1 血</view>
        <view class="rules-text">血量归零时卡牌死亡，扣 1 分</view>
        <view class="rules-text">∞血卡不会衰减</view>
      </view>
      <view class="rules-section">
        <view class="rules-subtitle">✨ 能力说明</view>
        <view class="rules-text">🔄 旋转：选择一张牌顺时针旋转 90°</view>
        <view class="rules-text">🎨 变色：选择一张牌变为激活卡牌的属性</view>
        <view class="rules-text">💫 换位：选择两张牌交换位置</view>
      </view>
    </scroll-view>
    <button class="btn btn-primary" bindtap="hideRules">知道了</button>
  </view>
</view>
